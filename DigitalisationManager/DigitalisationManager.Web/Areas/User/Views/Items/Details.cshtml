@model DigitalisationManager.Web.ViewModels.Item.ItemDetailsViewModel

@{
    ViewData["Title"] = "Item Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-0">@Model.InventoryNumber</h1>
        <div class="text-muted small">Fund: @Model.FundCode</div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary"
               asp-area="User"
               asp-action="Index">
            Back
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Inventory number</dt>
            <dd class="col-sm-9">@Model.InventoryNumber</dd>

            <dt class="col-sm-3">Fund</dt>
            <dd class="col-sm-9">@Model.FundCode</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">
                @Model.CategoryName
            </dd>

            <dt class="col-sm-3">Document date</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.DocumentDateText) ? "—" : Model.DocumentDateText)
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge bg-secondary">@Model.Status</span>
            </dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)
            </dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">
                @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") (UTC)
            </dd>

            <dt class="col-sm-3">Files</dt>
            <dd class="col-sm-9">
                <span class="badge bg-secondary">@Model.FilesCount</span>
            </dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <h2 class="h5">Item history</h2>

    @if (Model.HistoryEntries == null || Model.HistoryEntries.Count == 0)
    {
        <div class="text-muted">No history entries yet.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Action</th>
                            <th>Description</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.HistoryEntries)
                        {
                            <tr>
                                <td class="fw-semibold">@entry.Action</td>
                                <td>@(string.IsNullOrWhiteSpace(entry.Description) ? "—" : entry.Description)</td>
                                <td>@entry.CreatedAt.ToString("yyyy-MM-dd HH:mm") (UTC)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<div class="mt-4">
    <h2 class="h5">Digital files</h2>

    @if (Model.Files == null || Model.Files.Count == 0)
    {
        <div class="text-muted">No files are available for this item.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>File</th>
                        <th class="text-end">Size</th>
                        <th>Uploaded</th>
                        <th class="text-end">Download</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model.Files)
                    {
                        <tr>
                            <td>@file.OriginalFileName</td>
                            <td class="text-end">@file.OriginalSizeBytes.ToString("N0")</td>
                            <td>@file.UploadedAt.ToString("yyyy-MM-dd HH:mm") (UTC)</td>
                            <td class="text-end">
                                @if (file.IsDownloadAllowed)
                                {
                                    <a class="btn btn-sm btn-outline-primary"
                                           asp-area="User"
                                           asp-controller="DigitalFiles"
                                           asp-action="Download"
                                           asp-route-id="@file.Id">
                                        Download
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">Not available</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="small text-muted">
            Download availability will be added after the digital file access rules are introduced.
        </div>
    }
</div>