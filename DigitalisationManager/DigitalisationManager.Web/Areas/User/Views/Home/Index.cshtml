@{
    ViewData["Title"] = "User Home";
}

<div class="py-5 text-center">
    <div class="mx-auto" style="max-width: 760px;">
        <h1 class="display-5 fw-semibold mb-3">Welcome</h1>
        <p class="lead text-muted mb-3">
            Explore archival collections and discover digitised materials in a clear and easy-to-use environment.
        </p>
        <p class="text-muted mb-0">
            You can browse available funds, review archival items, and access related digital files through the sections below.
        </p>
    </div>
</div>

<div class="row mt-4 g-4 justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Funds</h2>
                <p class="text-muted mb-4">
                    Browse archival funds and explore the collections available in the system.
                </p>
                <a asp-area="User"
                       asp-controller="Funds"
                       asp-action="Index"
                       class="btn btn-primary px-4">
                    Browse Funds
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Items</h2>
                <p class="text-muted mb-4">
                    Review archival items and open the digital materials connected to them.
                </p>
                <a asp-area="User"
                       asp-controller="Items"
                       asp-action="Index"
                       class="btn btn-primary px-4">
                    Browse Items
                </a>
            </div>
        </div>
    </div>
</div>