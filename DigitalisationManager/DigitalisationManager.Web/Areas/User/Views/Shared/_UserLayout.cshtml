@using static DigitalisationManager.GCommon.ApplicationConstants
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DigitalisationManager</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DigitalisationManager.Web.styles.css" asp-append-version="true" />
</head>
<body class="user-shell">

    <header>
        <nav class="navbar navbar-expand-lg navbar-light user-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-semibold"
                       asp-area="User"
                       asp-controller="Home"
                       asp-action="Index">
                    DigitalisationManager User
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#userNavbar"
                        aria-controls="userNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="userNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @if (User.IsInRole(RoleNames.Administrator))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-area="Admin"
                                       asp-controller="Home"
                                       asp-action="Index">
                                    Dashboard
                                </a>
                            </li>
                        }
                        else if (User.IsInRole(RoleNames.Manager))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-area="Manager"
                                       asp-controller="Home"
                                       asp-action="Index">
                                    Dashboard
                                </a>
                            </li>
                        }
                        else
                            {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-area="User"
                                       asp-controller="Home"
                                       asp-action="Index">
                                    Dashboard
                                </a>
                            </li>
                            }

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-area="User"
                                   asp-controller="Items"
                                   asp-action="Index">
                                Browse Items
                            </a>
                        </li>

                     
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="container user-main py-4">
        @RenderBody()
    </main>

    <footer class="user-footer border-top">
        <div class="container py-3 text-muted small">
            &copy; 2026 - DigitalisationManager User Area
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>