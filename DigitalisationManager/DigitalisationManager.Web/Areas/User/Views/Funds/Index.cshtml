@model DigitalisationManager.Web.ViewModels.Funds.FundQueryViewModel

@{
    ViewData["Title"] = "Funds";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Funds</h1>
        <div class="text-muted">Browse archival funds and explore related items</div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" asp-area="User" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-10">
                <label class="form-label" for="q">Search</label>
                <input id="q"
                       name="q"
                       value="@Model.Q"
                       class="form-control"
                       placeholder="Code, title or description..." />
            </div>

            <div class="col-md-2 d-grid">
                <input type="hidden" name="page" value="1" />
                <button class="btn btn-outline-dark" type="submit">Apply</button>
            </div>

            <div class="col-12">
                <a class="small text-muted" asp-area="User" asp-action="Index">Clear search</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Results.Items.Count == 0)
{
    <div class="alert alert-info border">
        No funds found.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var fund in Model.Results.Items)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="mb-2">
                            <div class="small text-muted">Code</div>
                            <div class="fw-semibold">@fund.Code</div>
                        </div>

                        <div class="mb-2">
                            <div class="small text-muted">Title</div>
                            <div>@fund.Title</div>
                        </div>

                        <div class="mb-2">
                            <div class="small text-muted">Type</div>
                            <div>@fund.FundType</div>
                        </div>

                        <div class="mb-3">
                            <div class="small text-muted">Items</div>
                            <span class="badge bg-secondary">@fund.ItemsCount</span>
                        </div>

                        <div class="mt-auto">
                            <a class="btn btn-outline-primary w-100"
                               asp-area="User"
                               asp-controller="Items"
                               asp-action="Index"
                               asp-route-fundId="@fund.Id">
                                View Items
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4 d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="small text-muted">
            Page <span class="fw-semibold">@Model.Results.Page</span>
            @if (Model.Results.TotalPages > 0)
            {
                <span>of</span> <span class="fw-semibold">@Model.Results.TotalPages</span>
            }
            <span>• Total: <span class="fw-semibold">@Model.Results.TotalCount</span></span>
        </div>

        @if (Model.Results.TotalPages > 1)
        {
            <nav aria-label="Funds pagination">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.Results.HasPrevious ? "" : "disabled")">
                        <a class="page-link"
                           asp-area="User"
                           asp-action="Index"
                           asp-route-q="@Model.Q"
                           asp-route-page="@(Model.Results.Page - 1)">
                            Previous
                        </a>
                    </li>

                    <li class="page-item @(Model.Results.HasNext ? "" : "disabled")">
                        <a class="page-link"
                           asp-area="User"
                           asp-action="Index"
                           asp-route-q="@Model.Q"
                           asp-route-page="@(Model.Results.Page + 1)">
                            Next
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
}