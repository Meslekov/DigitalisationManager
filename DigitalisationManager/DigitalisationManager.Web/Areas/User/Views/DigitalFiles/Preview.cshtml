@model DigitalisationManager.Web.ViewModels.DigitalFile.DigitalFilePreviewViewModel

@{
    ViewData["Title"] = "Digital File Preview";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-0">@Model.OriginalFileName</h1>
        <div class="text-muted small">
            File @Model.Position of @Model.TotalCount
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary"
               asp-area="User"
               asp-controller="Items"
               asp-action="Details"
               asp-route-id="@Model.ItemId">
            Back to Item
        </a>

        @if (Model.CanDownloadPreview)
        {
            <a class="btn btn-primary"
                   asp-area="User"
                   asp-controller="DigitalFiles"
                   asp-action="Download"
                   asp-route-id="@Model.Id">
                Download JPG
            </a>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body text-center">
        <img src="@Model.PreviewImageUrl"
             alt="@Model.OriginalFileName"
             class="img-fluid rounded border" />
    </div>
</div>

<div class="mt-3 d-flex justify-content-between">
    <div>
        @if (Model.PreviousFileId.HasValue)
        {
            <a class="btn btn-outline-secondary"
                   asp-area="User"
                   asp-controller="DigitalFiles"
                   asp-action="Preview"
                   asp-route-id="@Model.PreviousFileId">
                Previous
            </a>
        }
    </div>

    <div>
        @if (Model.NextFileId.HasValue)
        {
            <a class="btn btn-outline-secondary"
                   asp-area="User"
                   asp-controller="DigitalFiles"
                   asp-action="Preview"
                   asp-route-id="@Model.NextFileId">
                Next
            </a>
        }
    </div>
</div>