@using DigitalisationManager.Web.ViewModels.Funds

@model FundDetailsViewModel

@{
    ViewData["Title"] = "Fund Details";
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-0">@Model.Code</h1>
        <div class="text-muted">@Model.Title</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
        <a class="btn btn-dark" asp-controller="Items" asp-action="Index" asp-route-fundId="@Model.Id">
            View Items (@Model.ItemsCount)
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Fund type</dt>
            <dd class="col-sm-9">@Model.FundType</dd>

            <dt class="col-sm-3">Code</dt>
            <dd class="col-sm-9">@Model.Code</dd>

            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "—")</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") (UTC)</dd>

            <dt class="col-sm-3">Items</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@Model.ItemsCount</span></dd>
        </dl>
    </div>
</div>

<a class="btn btn-outline-secondary mt-3" asp-action="Index">Back</a>

