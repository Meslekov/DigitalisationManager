@using DigitalisationManager.Web.ViewModels.Funds

@model FundDetailsViewModel
@{
    ViewData["Title"] = "Delete Fund";
}

<div class="mb-3">
    <h1 class="h4">Delete Fund</h1>
    <div class="text-muted">This action cannot be undone.</div>
</div>

<div class="alert alert-warning border">
    You are about to delete <strong>@Model.Code</strong> (<strong>@Model.Title</strong>).
    If the fund contains items, deletion will be blocked.
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.FundType</dd>

            <dt class="col-sm-3">Items</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@Model.ItemsCount</span></dd>
        </dl>

        <form class="mt-4" asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <button type="submit" class="btn btn-danger">Yes, delete</button>
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
        </form>
    </div>
</div>

