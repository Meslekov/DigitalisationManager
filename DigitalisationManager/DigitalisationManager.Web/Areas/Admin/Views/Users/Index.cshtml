@model IEnumerable<DigitalisationManager.Web.ViewModels.Admin.UserRoleManagementViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="container mt-4">
    <h1 class="mb-3">Users</h1>

    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Email</th>
                <th>Name</th>
                <th>Role</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@($"{user.FirstName} {user.LastName}")</td>
                    <td>@user.SelectedRole</td>
                    <td>
                        <a asp-area="Admin"
                               asp-controller="Users"
                               asp-action="EditRole"
                               asp-route-id="@user.UserId"
                               class="btn btn-sm btn-outline-primary">
                            Edit Role
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>