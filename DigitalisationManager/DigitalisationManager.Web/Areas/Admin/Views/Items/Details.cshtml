@model DigitalisationManager.Web.ViewModels.Item.ItemDetailsViewModel

@{
    ViewData["Title"] = "Item Details";
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-0">@Model.InventoryNumber</h1>
        <div class="text-muted small">Fund: @Model.FundCode</div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary"
               asp-area="Admin"
               asp-action="Edit"
               asp-route-id="@Model.Id">
            Edit
        </a>

        <a class="btn btn-outline-danger"
               asp-area="Admin"
               asp-action="Delete"
               asp-route-id="@Model.Id">
            Delete
        </a>

        <a class="btn btn-outline-secondary"
               asp-area="Admin"
               asp-action="Index">
            Back
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Inventory number</dt>
            <dd class="col-sm-9">@Model.InventoryNumber</dd>

            <dt class="col-sm-3">Fund</dt>
            <dd class="col-sm-9">@Model.FundCode</dd>

            <dt class="col-sm-3">Document date</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.DocumentDateText)
                    ? "—"
                    : Model.DocumentDateText)
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge bg-secondary">@Model.Status</span>
            </dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Description)
                    ? "—"
                    : Model.Description)
            </dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">
                @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") (UTC)
            </dd>

            <dt class="col-sm-3">Files</dt>
            <dd class="col-sm-9">
                <span class="badge bg-secondary">@Model.FilesCount</span>
            </dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <h2 class="h5">TIFF files</h2>

    <form asp-area="Admin"
          asp-controller="DigitalFiles"
          asp-action="Upload"
          method="post"
          enctype="multipart/form-data"
          class="border rounded p-3 mb-3">
        <input type="hidden"
               name="itemId"
               value="@Model.Id" />

        <div class="mb-2">
            <label class="form-label">Upload TIFF (.tif/.tiff)</label>

            <input class="form-control"
                   type="file"
                   name="file"
                   accept=".tif,.tiff,image/tiff" />
        </div>

        <button class="btn btn-primary" type="submit">
            Upload
        </button>
    </form>

    @if (Model.Files == null || Model.Files.Count == 0)
    {
        <div class="text-muted">No files uploaded yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>File</th>
                        <th class="text-end">Size</th>
                        <th>Uploaded</th>
                        <th>Download for users</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model.Files)
                    {
                        <tr>
                            <td>@file.OriginalFileName</td>
                            <td class="text-end">@file.SizeBytes.ToString("N0")</td>
                            <td>@file.UploadedAt.ToString("yyyy-MM-dd HH:mm") (UTC)</td>
                            <td>
                                @if (file.IsDownloadAllowed)
                                {
                                    <span class="badge bg-success">Allowed</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Blocked</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                    <a class="btn btn-sm btn-outline-secondary"
                                           asp-area="Admin"
                                           asp-controller="DigitalFiles"
                                           asp-action="Download"
                                           asp-route-id="@file.Id">
                                        Download
                                    </a>

                                    <form asp-area="Admin"
                                          asp-controller="DigitalFiles"
                                          asp-action="SetDownloadAllowed"
                                          method="post"
                                          class="d-inline">
                                        <input type="hidden" name="id" value="@file.Id" />
                                        <input type="hidden" name="itemId" value="@Model.Id" />
                                        <input type="hidden" name="isAllowed" value="@(file.IsDownloadAllowed ? "false" : "true")" />

                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            @(file.IsDownloadAllowed ? "Block for Users" : "Allow for Users")
                                        </button>
                                    </form>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteFileModal"
                                            data-file-id="@file.Id"
                                            data-item-id="@Model.Id"
                                            data-file-name="@file.OriginalFileName">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="modal fade"
     id="deleteFileModal"
     tabindex="-1"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete file</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <p class="mb-1">
                    Are you sure you want to delete
                    <strong id="deleteFileName"></strong>?
                </p>

                <small class="text-muted">
                    This action cannot be undone.
                </small>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <form id="deleteFileForm"
                      asp-area="Admin"
                      asp-controller="DigitalFiles"
                      asp-action="Delete"
                      method="post"
                      class="d-inline">
                    <input type="hidden" name="id" id="deleteFileId" />
                    <input type="hidden" name="itemId" id="deleteItemId" />

                    <button type="submit"
                            class="btn btn-danger">
                        Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteFileModal');

        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;

                const fileId = button.getAttribute('data-file-id');
                const itemId = button.getAttribute('data-item-id');
                const fileName = button.getAttribute('data-file-name');

                document.getElementById('deleteFileId').value = fileId;
                document.getElementById('deleteItemId').value = itemId;
                document.getElementById('deleteFileName').textContent = fileName;
            });
        }
    </script>
}