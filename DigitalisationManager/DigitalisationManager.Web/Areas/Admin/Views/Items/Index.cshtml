@model DigitalisationManager.Web.ViewModels.Item.ItemQueryViewModel

@{
    ViewData["Title"] = "Items";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Items</h1>
        <div class="text-muted">Browse archival items and filter by fund or keyword</div>
    </div>

    <a class="btn btn-primary" asp-area="Admin" asp-action="Create">Create Item</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" asp-area="Admin" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label" for="fundId">Fund</label>
                <select id="fundId" name="fundId" class="form-select">
                    <option value="">All funds</option>
                    @foreach (var fund in Model.Funds)
                    {
                        if (Model.FundId.HasValue && Model.FundId.Value.ToString() == fund.Value)
                        {
                            <option value="@fund.Value" selected>@fund.Text</option>
                        }
                        else
                        {
                            <option value="@fund.Value">@fund.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label" for="q">Search</label>
                <input id="q"
                       name="q"
                       value="@Model.Q"
                       class="form-control"
                       placeholder="Inventory number, description, document date, category..." />
            </div>

            <div class="col-md-2 d-grid">
                <input type="hidden" name="page" value="1" />
                <button class="btn btn-outline-dark" type="submit">Apply</button>
            </div>

            <div class="col-12">
                <a class="small text-muted" asp-area="Admin" asp-action="Index">Clear filters</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Results.Items.Count == 0)
{
    <div class="alert alert-info border">
        No items found. Try changing filters or create a new item.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Inventory number</th>
                        <th>Fund</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Document date</th>
                        <th>Status</th>
                        <th class="text-center">Files</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Results.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.InventoryNumber</td>
                            <td>@item.FundCode</td>
                            <td>@item.CategoryName</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Description) ? "—" : item.Description)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.DocumentDateText) ? "—" : item.DocumentDateText)</td>
                            <td>
                                <span class="badge bg-secondary">@item.Status</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@item.FilesCount</span>
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-area="Admin"
                                   asp-action="Details"
                                   asp-route-id="@item.Id">
                                    Details
                                </a>

                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-area="Admin"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id">
                                    Edit
                                </a>

                                <a class="btn btn-sm btn-outline-danger"
                                   asp-area="Admin"
                                   asp-action="Delete"
                                   asp-route-id="@item.Id">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body border-top d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="small text-muted">
                Page <span class="fw-semibold">@Model.Results.Page</span>
                @if (Model.Results.TotalPages > 0)
                {
                    <span>of</span> <span class="fw-semibold">@Model.Results.TotalPages</span>
                }
                <span>• Total: <span class="fw-semibold">@Model.Results.TotalCount</span></span>
            </div>

            @if (Model.Results.TotalPages > 1)
            {
                <nav aria-label="Items pagination">
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.Results.HasPrevious ? "" : "disabled")">
                            <a class="page-link"
                               asp-area="Admin"
                               asp-action="Index"
                               asp-route-fundId="@Model.FundId"
                               asp-route-q="@Model.Q"
                               asp-route-page="@(Model.Results.Page - 1)">
                                Previous
                            </a>
                        </li>

                        <li class="page-item @(Model.Results.HasNext ? "" : "disabled")">
                            <a class="page-link"
                               asp-area="Admin"
                               asp-action="Index"
                               asp-route-fundId="@Model.FundId"
                               asp-route-q="@Model.Q"
                               asp-route-page="@(Model.Results.Page + 1)">
                                Next
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
}