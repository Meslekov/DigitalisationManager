@{
    ViewData["Title"] = "Admin Home";
}

<div class="text-center py-4">
    <h1 class="display-5">Admin Panel</h1>
    <p class="lead text-muted">
        Welcome to the administration area of DigitalisationManager.
    </p>
</div>

<div class="row mt-4 g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">Funds</h2>
                <p class="text-muted">
                    Manage archival funds, descriptions, and structure.
                </p>
                <a asp-area="Admin"
                       asp-controller="Funds"
                       asp-action="Index"
                       class="btn btn-primary">
                    Open Funds
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">Items</h2>
                <p class="text-muted">
                    Manage archival items and digitalized materials.
                </p>
                <a asp-area="Admin"
                       asp-controller="Items"
                       asp-action="Index"
                       class="btn btn-primary">
                    Open Items
                </a>
            </div>
        </div>
    </div>
</div>