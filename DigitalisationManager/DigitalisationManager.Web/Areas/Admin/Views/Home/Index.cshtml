@{
    ViewData["Title"] = "Admin Home";
}

<div class="py-5 text-center">
    <div class="mx-auto" style="max-width: 760px;">
        <h1 class="display-5 fw-semibold mb-3">Welcome</h1>
        <p class="lead text-muted mb-3">
            Manage and organize the platform’s archival content in a clear and structured way.
        </p>
        <p class="text-muted mb-0">
            From here, you can maintain funds, review items, and ensure that digital materials are properly organised and accessible.
        </p>
    </div>
</div>

<div class="row mt-4 g-4 justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Manage Funds</h2>
                <p class="text-muted mb-4">
                    Create, edit, and organise archival funds within the system.
                </p>
                <a asp-area="Admin"
                       asp-controller="Funds"
                       asp-action="Index"
                       class="btn btn-primary px-4">
                    Open Funds
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Manage Items</h2>
                <p class="text-muted mb-4">
                    Review and maintain archival items and their associated digital files.
                </p>
                <a asp-area="Admin"
                       asp-controller="Items"
                       asp-action="Index"
                       class="btn btn-primary px-4">
                    Open Items
                </a>
            </div>
        </div>
    </div>
</div>

<div class="py-5"></div>