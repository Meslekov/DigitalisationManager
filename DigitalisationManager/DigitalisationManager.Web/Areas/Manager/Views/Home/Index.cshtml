@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="manager-page-header mb-4">
    <h1 class="mb-1">Manager Dashboard</h1>
    <p class="text-muted mb-0">
        Manage funds, items, and digital files.
    </p>
</div>

<div class="row g-4">

    <div class="col-md-6">
        <div class="card shadow-sm h-100 manager-card">
            <div class="card-body">
                <h2 class="h5">Items</h2>
                <p class="text-muted">
                    Create and manage archival items.
                </p>
                <a asp-area="Manager" asp-controller="Items" asp-action="Index"
                       class="btn btn-primary">
                    Open Items
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100 manager-card">
            <div class="card-body">
                <h2 class="h5">Funds</h2>
                <p class="text-muted">
                    Manage archival funds and structure.
                </p>
                <a asp-area="Manager" asp-controller="Funds" asp-action="Index"
                       class="btn btn-primary">
                    Open Funds
                </a>
            </div>
        </div>
    </div>

</div>