@using DigitalisationManager.Web.ViewModels.Item

@model ItemFormViewModel
@{
    ViewData["Title"] = "Edit Item";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-0">Edit Item</h1>
        <div class="text-muted small">Update item information</div>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <partial name="_ItemFormPartial" model="Model" />

            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-dark" type="submit">Save changes</button>
                <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
