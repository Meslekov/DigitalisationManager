@using DigitalisationManager.Web.ViewModels.Item

@model ItemDetailsViewModel
@{
    ViewData["Title"] = "Item Details";
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-0">@Model.InventoryNumber</h1>
        <div class="text-muted small">Fund: @Model.FundCode</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Inventory number</dt>
            <dd class="col-sm-9">@Model.InventoryNumber</dd>

            <dt class="col-sm-3">Fund</dt>
            <dd class="col-sm-9">@Model.FundCode</dd>

            <dt class="col-sm-3">Document date</dt>
            <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.DocumentDateText) ? Model.DocumentDateText : "—")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@Model.Status</span></dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "—")</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") (UTC)</dd>

            <dt class="col-sm-3">Files</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@Model.FilesCount</span></dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <h2 class="h5">TIFF files</h2>

    <form asp-controller="DigitalFiles" asp-action="Upload" method="post" enctype="multipart/form-data" class="border rounded p-3 mb-3">
        <input type="hidden" name="itemId" value="@Model.Id" />

        <div class="mb-2">
            <label class="form-label">Upload TIFF (.tif/.tiff)</label>
            <input class="form-control" type="file" name="file" accept=".tif,.tiff,image/tiff" />
        </div>

        <button class="btn btn-primary" type="submit">Upload</button>
    </form>

    @if (Model.Files.Count == 0)
    {
        <div class="text-muted">No files uploaded yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>File</th>
                        <th class="text-end">Size</th>
                        <th>Uploaded</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model.Files)
                    {
                        <tr>
                            <td>@f.OriginalFileName</td>
                            <td class="text-end">@($"{f.SizeBytes:N0}")</td>
                            <td>@f.UploadedAt.ToString("yyyy-MM-dd HH:mm") (UTC)</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-controller="DigitalFiles"
                                   asp-action="Download"
                                   asp-route-id="@f.Id">
                                    Download
                                </a>

                                <form class="d-inline"
                                      asp-controller="DigitalFiles"
                                      asp-action="Delete"
                                      method="post">
                                    <input type="hidden" name="id" value="@f.Id" />
                                    <input type="hidden" name="itemId" value="@Model.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit"
                                            onclick="return confirm('Delete this file?');">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>


