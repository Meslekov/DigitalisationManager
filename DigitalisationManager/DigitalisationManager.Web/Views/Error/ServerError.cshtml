@{
    ViewData["Title"] = "Server Error";
}

<div class="container py-5">
    <div class="mx-auto text-center" style="max-width: 700px;">
        <div class="display-1 fw-bold text-danger">500</div>

        <h1 class="h3 mb-3">Something went wrong</h1>

        <p class="text-muted mb-4">
            An unexpected error occurred while processing your request.
            Please try again later or return to the home page.
        </p>

        <div class="d-flex justify-content-center gap-2 flex-wrap">
            <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-primary">
                Go to Home
            </a>

            <button type="button"
                    class="btn btn-outline-secondary"
                    onclick="location.reload()">
                Try Again
            </button>
        </div>
    </div>
</div>