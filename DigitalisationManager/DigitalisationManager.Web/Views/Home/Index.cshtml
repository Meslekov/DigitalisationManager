@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-4">
    <h1 class="display-5">Welcome to DigitalisationManager</h1>
    <p class="lead text-muted">
        A digital archive management system for organizing and exploring archival materials.
    </p>
</div>

<div class="row mt-4 g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">User Portal</h2>
                <p class="text-muted">
                    Browse archival funds, items, and digitalized materials through the user-facing portal.
                </p>
                <p class="mb-0">
                    This area will provide a simplified browsing experience separate from the administration panel.
                </p>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Administrator"))
    {
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Administration</h2>
                    <p class="text-muted">
                        Access the administration panel to manage funds, items, digital files, and system data.
                    </p>
                    <a asp-area="Admin"
                           asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-primary">
                        Open Admin Panel
                    </a>
                </div>
            </div>
        </div>
    }
</div>