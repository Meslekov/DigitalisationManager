@{
    ViewData["Title"] = "Home Page";
}

<div class="row g-4">
    <div class="col-12">
        <div class="p-4 bg-light rounded-3 border">
            <h1 class="h3 mb-2">DigitalisationManager</h1>
            <p class="mb-0 text-muted">
                Manage your archival funds.
            </p>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Funds</h2>
                <p class="text-muted">Create and manage archival groupings (Archive, Photo, Icon...).</p>
                <a class="btn btn-dark" asp-controller="Funds" asp-action="Index">Open Funds</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Items</h2>
                <p class="text-muted">Create items, track status, and attach TIFF digitizations.</p>
                <a class="btn btn-dark" asp-controller="Items" asp-action="Index">Open Items</a>
            </div>
        </div>
    </div>
</div>
